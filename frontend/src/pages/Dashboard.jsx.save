import { useEffect, useMemo, useState } from "react";

import Recommendations from "../components/Recommendations";
import FeaturedRestaurantCard from "../components/FeaturedRestaurantCard";
import FeaturedMealCard from "../components/FeaturedMealCard";
import api from "../services/api";
import useMenu from "../hooks/useMenu";

import healthyBowl from "../assets/food/healthy-spinach-bowl.jpg";
import bbqPlatter from "../assets/food/grilled-bbq-platter.jpg";
import pizza from "../assets/food/hawaiian-chicken-pizza.jpg";
import cheesecake from "../assets/food/orange-cheesecake.jpg";
import skewers from "../assets/food/grilled-beef-skewers.jpg";
import bbqChicken from "../assets/food/bbq-sausages-and-chicken.jpg";

import restaurant1 from "../assets/restaurants/restaurant-1.jpg";
import restaurant2 from "../assets/restaurants/restaurant-2.jpg";
import restaurant3 from "../assets/restaurants/restaurant-3.jpg";
import restaurant4 from "../assets/restaurants/restaurant-4.jpg";

const restaurantImages = [
  restaurant1,
  restaurant2,
  restaurant3,
  restaurant4,
];

function getFoodImage(name = "", tags = "") {
  const text = `${name} ${tags}`.toLowerCase();

  if (text.includes("pizza")) return pizza;

  if (
    text.includes("bbq") ||
    text.includes("sausage")
  ) {
    return bbqChicken;
  }

  if (
    text.includes("burger") ||
    text.includes("chicken")
  ) {
    return bbqPlatter;
  }

  if (
    text.includes("beef") ||
    text.includes("steak") ||
    text.includes("skewer")
  ) {
    return skewers;
  }

  if (
    text.includes("cake") ||
    text.includes("dessert") ||
    text.includes("muffin")
  ) {
    return cheesecake;
  }

  return healthyBowl;
}

function Dashboard({ setActivePage, openRestaurant }) {
  const [restaurants, setRestaurants] = useState([]);
  const [menuItems, setMenuItems] = useState([]);
  const [deals, setDeals] = useState([]);
  const [loading, setLoading] = useState(true);
  const [message, setMessage] = useState("");

  useEffect(() => {
    async function loadDashboard() {
      try {
        setLoading(true);
        setMessage("");

        const [
          restaurantsResponse,
          menuResponse,
          dealsResponse,
        ] = await Promise.all([
          api.get("/restaurants/"),
          api.get("/menu/"),
          api.get("/deals/"),
        ]);

        setRestaurants(
          Array.isArray(restaurantsResponse.data)
            ? restaurantsResponse.data
            : []
        );

        setMenuItems(
          Array.isArray(menuResponse.data)
            ? menuResponse.data
            : []
        );

        setDeals(
          Array.isArray(dealsResponse.data)
            ? dealsResponse.data
            : []
        );
      } catch (error) {
        console.error("Dashboard loading failed:", error);
        setMessage(
          "Some dashboard information could not be loaded."
        );
      } finally {
        setLoading(false);
      }
    }

    loadDashboard();
  }, []);

  const featuredRestaurants = useMemo(
    () => restaurants.slice(0, 3),
    [restaurants]
  );

  const featuredMeals = useMemo(
    () =>
      [...menuItems]
        .sort(
          (first, second) =>
            Number(first.price || 0) -
            Number(second.price || 0)
        )
        .slice(0, 4),
    [menuItems]
  );

  function handleRestaurantClick(restaurant, image) {
    if (typeof openRestaurant === "function") {
      openRestaurant({
        ...restaurant,
        image,
      });
    }
  }

  return (
    <main className="premium-dashboard">
      <section className="premium-hero">
        <div className="premium-hero-copy">
          <span className="premium-eyebrow">
            AI-powered campus food discovery
          </span>

          <h1>
            Find your next meal,
            <span> without the guesswork.</span>
          </h1>

          <p>
            Discover affordable meals, nearby restaurants,
            flash deals, and personalized recommendations in
            one place.
          </p>

          <div className="premium-hero-actions">
            <button
              type="button"
              className="premium-primary-button"
              onClick={() => setActivePage("search")}
            >
              Search for food
              <span>→</span>
            </button>

            <button
              type="button"
              className="premium-secondary-button"
              onClick={() => setActivePage("restaurants")}
            >
              Browse restaurants
            </button>
          </div>

          <div className="premium-stats">
            <div>
              <strong>
                {loading ? "—" : restaurants.length}
              </strong>
              <span>Restaurants</span>
            </div>

            <div>
              <strong>
                {loading ? "—" : menuItems.length}
              </strong>
              <span>Meals</span>
            </div>

            <div>
              <strong>
                {loading ? "—" : deals.length}
              </strong>
              <span>Live deals</span>
            </div>
          </div>
        </div>

        <div className="premium-hero-media">
          <img
            src={healthyBowl}
            alt="Healthy meal available on CampusEats"
          />

          <div className="premium-media-overlay" />

          <div className="premium-floating-card premium-floating-top">
            <span>✨</span>

            <div>
              <strong>Smart recommendations</strong>
              <small>Based on your interests</small>
            </div>
          </div>

          <div className="premium-floating-card premium-floating-bottom">
            <span>🔥</span>

            <div>
              <strong>{deals.length} active deals</strong>
              <small>Save before they expire</small>
            </div>
          </div>
        </div>
      </section>

      {message && (
        <div className="premium-dashboard-message">
          {message}
        </div>
      )}

      <section className="premium-quick-section">
        <div className="premium-section-heading">
          <div>
            <span className="premium-eyebrow">
              Quick access
            </span>
            <h2>What would you like to do?</h2>
          </div>
        </div>

        <div className="premium-quick-grid">
          <button
            type="button"
            className="premium-quick-card"
            onClick={() => setActivePage("restaurants")}
          >
            <span className="premium-quick-icon">🍽️</span>

            <div>
              <h3>Explore restaurants</h3>
              <p>
                Browse locations, opening hours, and menus.
              </p>
            </div>

            <span className="premium-card-arrow">→</span>
          </button>

          <button
            type="button"
            className="premium-quick-card"
            onClick={() => setActivePage("menu")}
          >
            <span className="premium-quick-icon">📋</span>

            <div>
              <h3>Browse meals</h3>
              <p>
                Compare prices, ingredients, and dietary tags.
              </p>
            </div>

            <span className="premium-card-arrow">→</span>
          </button>

          <button
            type="button"
            className="premium-quick-card"
            onClick={() => setActivePage("search")}
          >
            <span className="premium-quick-icon">✨</span>

            <div>
              <h3>Ask CampusEats AI</h3>
              <p>
                Search naturally by food, budget, or preference.
              </p>
            </div>

            <span className="premium-card-arrow">→</span>
          </button>
        </div>
      </section>

      <section className="premium-content-section">
        <div className="premium-section-heading">
          <div>
            <span className="premium-eyebrow">
              Popular nearby
            </span>
            <h2>Featured restaurants</h2>
          </div>

          <button
            type="button"
            className="premium-text-button"
            onClick={() => setActivePage("restaurants")}
          >
            View all →
          </button>
        </div>

        {loading ? (
          <div className="premium-loading-card">
            Loading restaurants...
          </div>
        ) : featuredRestaurants.length === 0 ? (
          <div className="premium-empty-card">
            No restaurants are available yet.
          </div>
        ) : (
          <div className="premium-restaurant-grid">
            {featuredRestaurants.map(
              (restaurant, index) => {
                const image =
                  restaurantImages[
                    index % restaurantImages.length
                  ];

                return (
                  <FeaturedRestaurantCard
                    key={restaurant.id}
                    restaurant={restaurant}
                    image={image}
                    onOpen={handleRestaurantClick}
                  />
                );
              }
            )}
          </div>
        )}
      </section>

      <section className="premium-content-section">
        <div className="premium-section-heading">
          <div>
            <span className="premium-eyebrow">
              Student-friendly prices
            </span>
            <h2>Affordable meals</h2>
          </div>

          <button
            type="button"
            className="premium-text-button"
            onClick={() => setActivePage("menu")}
          >
            View menu →
          </button>
        </div>

        {loading ? (
          <div className="premium-loading-card">
            Loading meals...
          </div>
        ) : featuredMeals.length === 0 ? (
          <div className="premium-empty-card">
            No meals are available yet.
          </div>
        ) : (
          <div className="premium-meal-grid">
            {featuredMeals.map((item) => (
              <FeaturedMealCard
                key={item.id}
                item={item}
                imageSrc={getFoodImage(
                  item.name,
                  item.tags
                )}
                onOpen={() =>
                  setActivePage("menu")
                }
              />
            ))}
          </div>
        )}
      </section>

      <Recommendations />

      <section className="premium-bottom-banner">
        <div>
          <span className="premium-eyebrow">
            CampusEats AI
          </span>

          <h2>
            Not sure what to eat?
          </h2>

          <p>
            Ask for something like “healthy high-protein
            food under $10.”
          </p>
        </div>

        <button
          type="button"
          onClick={() => setActivePage("chat")}
        >
          Open AI assistant →
        </button>
      </section>
    </main>
  );
}

export default Dashboard;


